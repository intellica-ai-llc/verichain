on-error: [
  trap ERR,
  effect-based recovery,
  diagnostic_classify,
  consistency_repair,
]
on-drift: [
  §SAFETY-CONTRACTS violation → halt,
  else → notify_and_await,
  multi_anchor_verification,
]
on-dream: [
  review_today,
  resolve_contradictions,
  consolidate_episodic_to_semantic,
  compress_observations,
  prune_by_decay,
  update_memory_file,
]
