§COGNITIVE-MESH
# CAT7 schema, SVAF acceptance, lineage, remix storage.

cmb_schema CAT7 {
  agent_id: AgentID,
  timestamp: ISO8601,
  role: Role,
  content_hash: SHA256,
  parent_hashes: [SHA256],
  anchors: RoleIndexedAnchors,
