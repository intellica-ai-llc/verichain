impl fmt::Display for TokenKind {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{:?}", self)
    }
}

// ── Helper: check if a keyword string matches ──
pub fn keyword_from_str(word: &str) -> Option<TokenKind> {
    Some(match word {
        // S0
        "agent"            => TokenKind::KwAgent,
